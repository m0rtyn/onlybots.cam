---
import Layout from '@/shared/layouts/Layout.astro';
import PlatformHeader from '@/features/bait-phase/components/platform-header.astro';
import LandingGrid from '@/features/bait-phase/components/landing-grid.astro';
import TheSwitch from '@/features/the-switch/components/the-switch';
import TheRealCost from '@/features/reveal-phase/components/the-real-cost.astro';
import BehindTheScreen from '@/features/reveal-phase/components/behind-the-screen.astro';
import TheMachine from '@/features/reveal-phase/components/the-machine.astro';
import WhatYouCanDo from '@/features/reveal-phase/components/what-you-can-do.astro';
import WhyIBuiltThis from '@/features/reveal-phase/components/why-i-built-this.astro';
import PlatformFooter from '@/features/bait-phase/components/platform-footer.astro';
---

<Layout>
  <TheSwitch client:load>
    <PlatformHeader />
    <main id="main-content" class="bait-content min-h-screen flex flex-col">
      <LandingGrid />
    </main>
  </TheSwitch>

  <!-- Reveal sections (hidden until switch, animated in by TheSwitch via .reveal-section DOM queries) -->
  <div id="reveal-content" role="region" aria-label="Revealed content about the webcam industry">
    <TheRealCost />
    <BehindTheScreen />
    <TheMachine />
    <WhatYouCanDo />
    <WhyIBuiltThis />
  </div>

  <PlatformFooter />
</Layout>
