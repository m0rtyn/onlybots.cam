---
import Layout from '@/shared/layouts/Layout.astro';
import PlatformHeader from '@/features/bait-phase/components/platform-header.astro';
import LandingGrid from '@/features/bait-phase/components/landing-grid.astro';
import TheSwitch from '@/features/the-switch/components/the-switch';
import TheRealCost from '@/features/reveal-phase/components/the-real-cost.astro';
import BehindTheScreen from '@/features/reveal-phase/components/behind-the-screen.astro';
import TheMachine from '@/features/reveal-phase/components/the-machine.astro';
import WhatYouCanDo from '@/features/reveal-phase/components/what-you-can-do.astro';
import WhyIBuiltThis from '@/features/reveal-phase/components/why-i-built-this.astro';
import PlatformFooter from '@/features/bait-phase/components/platform-footer.astro';
---

<Layout>
  <TheSwitch client:load>
    <PlatformHeader />
    <main id="main-content" class="bait-content min-h-screen flex flex-col">
      <LandingGrid />
    </main>
  </TheSwitch>

  <!-- Reveal sections (hidden until switch, animated in by TheSwitch via .reveal-section DOM queries) -->
  <div id="reveal-content" role="region" aria-label="Revealed content about the webcam industry">
    <TheRealCost />
    <BehindTheScreen />
    <TheMachine />
    <WhatYouCanDo />
    <WhyIBuiltThis />
  </div>

  <PlatformFooter />
</Layout>

<script>
  /** Plausible scroll_depth tracking — fires once per reveal section reached */
  function initScrollTracking(): void {
    const sections = document.querySelectorAll<HTMLElement>('.reveal-section');
    if (!sections.length) return;

    const total = sections.length;
    const reached = new Set<number>();

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const idx = Array.from(sections).indexOf(entry.target as HTMLElement);
          if (idx === -1 || reached.has(idx)) continue;
          reached.add(idx);
          const depth = Math.round(((idx + 1) / total) * 100);
          window.plausible?.('scroll_depth', {
            props: { depth: `${depth}%` },
            interactive: false,
          });
          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.3 },
    );

    sections.forEach((s) => observer.observe(s));
  }

  // Start tracking when reveal state activates (or immediately for returning visitors)
  if (document.body.classList.contains('reveal-state')) {
    initScrollTracking();
  } else {
    const mo = new MutationObserver(() => {
      if (document.body.classList.contains('reveal-state')) {
        mo.disconnect();
        initScrollTracking();
      }
    });
    mo.observe(document.body, { attributes: true, attributeFilter: ['class'] });
  }
</script>
