---

<section class="landing-grid max-w-7xl mx-auto px-4 py-8" data-phase="bait">
  <!-- Online count -->
  <div class="flex items-center gap-2 mb-6">
    <span class="relative flex h-2.5 w-2.5">
      <span class="animate-pulse-slow absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
    </span>
    <span class="text-sm text-gray-400">1,247 models online now</span>
  </div>

  <!-- Card grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    {cards.map((card) => (
      <ProfileCard {...card} />
    ))}
  </div>

  <!-- Load More button -->
  <div class="flex justify-center mt-10">
    <button class="load-more-btn bg-dark-surface hover:bg-gray-800 transition-colors text-gray-300 text-sm font-medium px-8 py-2.5 rounded-full border border-gray-700/50">
      Load More
    </button>
  </div>

  <!-- Bot typing indicator -->
  <div class="flex items-center justify-center gap-2 mt-6 text-gray-500 text-sm">
    <span>🤖</span>
    <span>Bot is typing<span class="typing-dots"></span></span>
  </div>
</section>
