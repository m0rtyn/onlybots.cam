---
// LandingGrid.astro — Main grid of ProfileCards driven by statistics.json
import ProfileCard from './ProfileCard.astro';
import statisticsData from '../data/statistics.json';

// Bot-style presentation data for each card (visual chrome for the "bait" face)
const botProfiles = [
  { name: 'Model_4827', badge: '🔥 Live Now', fans: '4,892', rating: '4.9', price: '$9.99', avatarSeed: 4827 },
  { name: 'Unit_0093',  badge: '✨ New',      fans: '1,247', rating: '4.7', price: '$14.99', avatarSeed: 93 },
  { name: 'Entity_7741', badge: '⭐ Top Rated', fans: '12,408', rating: '5.0', price: '$19.99', avatarSeed: 7741 },
  { name: 'Synth_3319', badge: '🔥 Live Now', fans: '3,156', rating: '4.8', price: '$7.99', avatarSeed: 3319 },
  { name: 'Pixel_8856', badge: '✨ New',      fans: '891',   rating: '4.6', price: '$11.99', avatarSeed: 8856 },
  { name: 'Nova_2104',  badge: '🔥 Live Now', fans: '6,723', rating: '4.9', price: '$9.99', avatarSeed: 2104 },
  { name: 'Echo_5567',  badge: '⭐ Top Rated', fans: '8,341', rating: '4.8', price: '$24.99', avatarSeed: 5567 },
  { name: 'Void_9902',  badge: '✨ New',      fans: '2,034', rating: '4.7', price: '$12.99', avatarSeed: 9902 },
];

// Merge bot profiles with statistics data (take first 9 stats)
const cards = statisticsData.slice(0, 9).map((stat, i) => ({
  ...botProfiles[i % botProfiles.length],
  statId: stat.id,
  baitLabel: stat.baitLabel,
  baitValue: stat.baitValue,
  revealStat: stat.revealStat,
  revealText: stat.revealDetail,
  revealSource: stat.source,
  revealSourceUrl: stat.sourceUrl,
}));
---

<!-- Every "Subscribe" button on this page is a door to the truth. What happens next might change how you see the industry. -->
<section class="landing-grid max-w-7xl mx-auto px-4 py-12 flex-1 flex flex-col justify-center" data-phase="bait">
  <!-- Online count -->
  <div class="flex items-center gap-2 mb-8">
    <span class="relative flex h-2.5 w-2.5">
      <span class="animate-pulse-slow absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
    </span>
    <span class="online-counter text-sm text-gray-400">1,247 models online now</span>
  </div>

  <!-- Card grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
    {cards.map((card, index) => (
      <ProfileCard {...card} index={index} />
    ))}
  </div>

  <!-- Load More button -->
  <div class="flex justify-center mb-8">
    <button class="load-more-btn bg-dark-surface hover:bg-gray-800 transition-colors text-gray-300 text-sm font-medium px-8 py-2.5 rounded-full border border-gray-700/50 cursor-pointer">
      Load More
    </button>
  </div>

  <!-- Bot typing indicator -->
  <div class="flex items-center justify-center gap-2 mt-6 text-gray-500 text-sm">
    <span>🤖</span>
    <span>Bot is typing<span class="typing-dots"></span></span>
  </div>
</section>
