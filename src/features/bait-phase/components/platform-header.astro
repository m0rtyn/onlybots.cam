---
// PlatformHeader.astro — Sticky nav bar mimicking a webcam platform
---

<header class="platform-header sticky top-0 z-50 w-full bg-[#0a0a0a] border-b border-gray-800/50" data-phase="bait">
  <!-- Main nav row -->
  <div class="flex items-center justify-between h-[60px] max-w-7xl mx-auto px-4">
    <!-- Left: Logo -->
    <div class="logo-wrap" style="overflow: visible;">
      <a href="#" class="flex items-center gap-0 shrink-0 relative z-10" style="overflow: visible;">
        <span class="logo-main text-xl font-bold text-white tracking-tight">onlybots</span>
        <span class="logo-accent text-xl font-bold text-neon-pink neon-glow-text">.cam</span>
        <!-- Blood drip elements -->
        <span class="logo-drip" style="top: 20.3px; left:10.3%; width:2px; height:85px; animation-delay:0.8s; animation-duration:13.5s;" aria-hidden="true"></span>
        <span class="logo-drip" style="top: 19px; left:34.9%; width:3px; height:110px; animation-delay:2.0s; animation-duration:14.5s;" aria-hidden="true"></span>
        <span class="logo-drip" style="top: 17.8px; left:55.7%; width:2px; height:95px; animation-delay:3.2s; animation-duration:13.0s;" aria-hidden="true"></span>
        <span class="logo-drip" style="top: 20.4px; left:71.2%; width:2px; height:45.5px; animation-delay:1.2s; animation-duration:15.0s;" aria-hidden="true"></span>
        <span class="logo-drip" style="top: 17px; left:87.3%; width:2px; height:120px; animation-delay:2.8s; animation-duration:14.0s;" aria-hidden="true"></span>
      </a>
    </div>

    <!-- Center: Fake search bar -->
    <div class="hidden md:flex flex-1 max-w-md mx-6">
      <div class="relative w-full">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          placeholder="Search models..."
          class="w-full bg-dark-surface text-sm text-gray-300 placeholder-gray-500 rounded-full pl-10 pr-4 py-2 border border-gray-700/50 focus:outline-none focus:border-neon-pink/40 cursor-not-allowed"
          disabled
          aria-label="Search models (decorative, non-functional)"
        />
      </div>
    </div>

    <!-- Right: Notification bell + avatar -->
    <div class="flex items-center gap-4 shrink-0">
      <!-- Notification bell -->
      <button class="relative text-gray-400 hover:text-white transition-colors cursor-default" aria-label="Notifications (decorative)" aria-hidden="true" tabindex="-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
        <!-- Red badge -->
        <span class="absolute -top-1 -right-1.5 bg-red-500 text-white text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center leading-none">3</span>
      </button>

      <!-- Fake user avatar -->
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-neon-pink to-purple-600 flex items-center justify-center text-white text-xs font-bold ring-2 ring-gray-700 cursor-default" aria-hidden="true">
        U
      </div>
    </div>
  </div>

  <!-- Secondary nav: category links -->
  <nav class="max-w-7xl mx-auto px-4 pb-2 flex items-center gap-6 overflow-x-auto scrollbar-hide" aria-label="Category navigation (decorative)" aria-hidden="true">
    <a href="#" class="text-sm text-gray-400 hover:text-neon-pink transition-colors whitespace-nowrap font-medium">
      Explore
    </a>
    <a href="#" class="text-sm text-gray-400 hover:text-neon-pink transition-colors whitespace-nowrap font-medium">
      Categories
    </a>
    <a href="#" class="text-sm text-neon-pink whitespace-nowrap font-medium">
      New
    </a>
    <a href="#" class="text-sm text-gray-400 hover:text-neon-pink transition-colors whitespace-nowrap font-medium">
      Top Rated
    </a>
  </nav>
</header>

<style>
  .logo-drip {
    position: absolute;
    top: 100%;
    background: linear-gradient(180deg, 
      #cc0000 0%,     /* bright red at top */
      #991b1b 30%,    /* darker red */
      #7f1d1d 70%,    /* very dark red */
      #450a0a 90%,    /* almost black */
      transparent 100%
    );
    border-radius: 0 0 100% 100%;  /* more teardrop */
    box-shadow: 
      0 4px 8px rgba(220, 38, 38, 0.6),
      inset 0 0 6px rgba(0, 0, 0, 0.03);
    pointer-events: none;
    z-index: 60;
    display: none;
    transform-origin: top center;
  }

  :global(.reveal-state) .logo-drip {
    display: block;
    animation-name: logoDrip;
    animation-timing-function: ease-in-out;
    animation-iteration-count: 1;
    animation-fill-mode: forwards;
  }

  @keyframes logoDrip {
    0%   { opacity: 0; transform:  scaleY(0); }
    5%   { opacity: 0.3; transform: scaleY(0.2); }
    15%  { opacity: 0.9; transform:  scaleY(0.6); }
    35%  { opacity: 0.95; transform: scaleY(1); }
    78%  { opacity: 0.8; transform: scaleY(1.1); }
    80%  { opacity: 0.8; transform: scaleY(0.95); }
    100% { opacity: 1; transform: scaleY(1); }
  }
</style>
