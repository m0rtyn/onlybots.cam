---
import ExternalLink from '@/shared/components/ui/external-link.astro';
import SectionHeading from '@/shared/components/ui/section-heading.astro';

const paragraphs = [
  "I'm a developer. A few years ago I interviewed with the company behind Stripchat — I would have taken the offer if I'd passed. At the time I figured the webcam industry was sleazy but functional: models have rights, money gets paid, everyone's consenting. I didn't think about it much after that.",
  "Then Ivan Roganov wrote a comment on vas3k.club that laid out what the industry actually looks like from the inside — the contracts that change after signing, studios making tens of thousands a night while models get hundreds, performers who looked happy at 25 but had no family, no relationships, and no way back at 40. It was the single biggest shift in my thinking in 2025.",
  "I came up with the domain name first. Then I bought it. Then I spent weeks reading Human Rights Watch reports, ICIJ investigations, and academic studies. Every number on this page links to its primary source. Nothing is made up. I wish some of it were.",
  "This isn't aimed at viewers or the people on camera. It's aimed at the platforms and studios that take most of the money and look away when things go wrong. If something here surprised you — share the page, check out the organizations above, and carry it with you.",
];
---

<section class="reveal-section opacity-0 max-w-3xl mx-auto py-24 px-6">
  <div class="border-t border-gray-800 mb-16"></div>

  <SectionHeading color="#d1d5db" glowColor="rgba(255, 255, 255, 0.1)" class="text-2xl mb-8">
    Why I Built This
  </SectionHeading>

  {paragraphs.map((p) => (
    <p class="text-gray-400 font-mono text-base leading-relaxed mb-6">
      {p}
    </p>
  ))}

  <div class="mt-12">
    <ExternalLink
      href="https://github.com/m0rtyn/onlybots.cam"
      class="text-electric-blue text-sm font-mono hover:underline underline-offset-2"
    >
      View source on GitHub
    </ExternalLink>
    <p class="text-xs text-gray-500 mt-2 font-mono">
      Built with Astro, Tailwind CSS, and GSAP
    </p>
  </div>
</section>
