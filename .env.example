# Environment Variables for onlybots.cam
# Copy this to .env.local for local development

# Analytics (optional)
# PLAUSIBLE_DOMAIN=onlybots.cam
# UMAMI_WEBSITE_ID=your-umami-id

# For production builds (automatically set by hosting platforms)
# NODE_ENV=production
# PUBLIC_SITE_URL=https://onlybots.cam

# Content Security Policy nonce (auto-generated if not set)
# CSP_NONCE=auto

# Debug mode (set to '1' to enable, leave empty for production)
# PUBLIC_DEBUG_MODE=

# Deployment platform detection (automatically set)
# VERCEL=1
# NETLIFY=1
# CF_PAGES=1
